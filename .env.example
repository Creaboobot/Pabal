# App
APP_URL=http://localhost:3000
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# Local Docker port overrides
APP_PORT=3000
POSTGRES_PORT=5432

# Seed data
SEED_DEMO_DATA=false

# Auth
# Required at runtime. Generate a local value with:
#   pnpm exec auth secret
AUTH_SECRET=replace-with-a-local-random-auth-secret
ENABLE_DEV_AUTH=false

# Optional future Microsoft Entra OAuth provider.
# These variables are for app sign-in readiness, not Microsoft Graph sync.
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=

# Database
# Local Docker Compose default:
DATABASE_URL=postgresql://pobal:pobal@localhost:5432/pobal?schema=public

# OpenAI / AI provider adapters
# Step 11A uses a server-side speech-to-text provider adapter.
# Step 11B uses a server-side transcript-structuring provider adapter.
# OPENAI_API_KEY is not required for build/readiness, but OpenAI transcription
# and transcript structuring require it at runtime when their provider is openai.
# Set mock providers only for local/test development; they are rejected in production.
SPEECH_TO_TEXT_PROVIDER=openai
TRANSCRIPT_STRUCTURING_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_STRUCTURING_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=

# Storage
STORAGE_PROVIDER=s3
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Jobs
JOB_PROVIDER=inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Billing readiness
# Step 13B defaults to the disabled provider. Stripe variables are documented
# for future live billing only and are not required for build/readiness.
BILLING_PROVIDER=disabled
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=

# Telemetry
SENTRY_DSN=

# Feature flags
FEATURE_MICROSOFT_GRAPH=false
FEATURE_LINKEDIN_MANUAL_ENRICHMENT=true
FEATURE_VOICE_CAPTURE=true
FEATURE_BILLING=false

# Microsoft Graph readiness
# Step 12A is readiness-only: no OAuth flow, token storage, sync, or ingestion.
# Keep the provider disabled unless explicitly running local/test provider tests.
MICROSOFT_GRAPH_PROVIDER=disabled
MICROSOFT_GRAPH_CLIENT_ID=
MICROSOFT_GRAPH_CLIENT_SECRET=
MICROSOFT_GRAPH_TENANT_ID=
MICROSOFT_GRAPH_AUTHORITY=
MICROSOFT_GRAPH_REDIRECT_URI=
