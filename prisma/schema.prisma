  createdByUser         User?               @relation("CommitmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser         User?               @relation("CommitmentUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
