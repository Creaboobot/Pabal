generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
}

enum RoleKey {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum RelationshipStatus {
  UNKNOWN
  ACTIVE
  DORMANT
  ARCHIVED
}

enum RelationshipTemperature {
  UNKNOWN
  COLD
  COOL
  NEUTRAL
  WARM
  HOT
}

enum MeetingParticipantRole {
  UNKNOWN
  ORGANIZER
  HOST
  ATTENDEE
  OPTIONAL
}

enum RecordSourceType {
  MANUAL
  TEAMS_COPILOT_PASTE
  LINKEDIN_USER_PROVIDED
}

enum NoteType {
  GENERAL
  PERSON
  COMPANY
  MEETING
  SOURCE_EXCERPT
}

enum Sensitivity {
  NORMAL
  SENSITIVE_BUSINESS
  PERSONAL
  CONFIDENTIAL
  DO_NOT_USE_IN_OUTREACH
  DO_NOT_SHARE
}

enum SourceEntityType {
  PERSON
  COMPANY
  COMPANY_AFFILIATION
  MEETING
  MEETING_PARTICIPANT
  NOTE
  TASK
  COMMITMENT
  NEED
  CAPABILITY
  INTRODUCTION_SUGGESTION
  AI_PROPOSAL
  AI_PROPOSAL_ITEM
  VOICE_NOTE
  VOICE_MENTION
}

enum TaskStatus {
  OPEN
  SNOOZED
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskType {
  FOLLOW_UP
  COMMITMENT
  INTRODUCTION
  MEETING_PREP
  RELATIONSHIP_MAINTENANCE
  OTHER
}

enum CommitmentOwnerType {
  ME
  OTHER_PERSON
  COMPANY
  UNKNOWN
}

enum CommitmentStatus {
  OPEN
  WAITING
  DONE
  CANCELLED
  OVERDUE
}

enum NeedType {
  PROBLEM
  REQUIREMENT
  REQUEST
  OPPORTUNITY
  INTEREST
  RISK
  QUESTION
  UNKNOWN
}

enum NeedStatus {
  OPEN
  IN_PROGRESS
  ADDRESSED
  PARKED
  CLOSED
}

enum CapabilityType {
  EXPERTISE
  ACCESS
  ASSET
  SERVICE_POTENTIAL
  EXPERIENCE
  SOLUTION
  OTHER
}

enum CapabilityStatus {
  ACTIVE
  PARKED
  RETIRED
  ARCHIVED
}

enum IntroductionSuggestionStatus {
  PROPOSED
  ACCEPTED
  OPT_IN_REQUESTED
  INTRO_SENT
  COMPLETED
  REJECTED
  PARKED
}

enum AIProposalType {
  NOTE_EXTRACTION
  VOICE_NOTE_EXTRACTION
  MEETING_EXTRACTION
  RELATIONSHIP_UPDATE
  FOLLOW_UP_SUGGESTION
  INTRODUCTION_SUGGESTION
  OTHER
}

enum AIProposalStatus {
  PENDING_REVIEW
  IN_REVIEW
  APPROVED
  PARTIALLY_APPROVED
  REJECTED
  DISMISSED
}

enum AIProposalActionType {
  CREATE
  UPDATE
  ARCHIVE
  LINK
  UNLINK
  NO_OP
}

enum AIProposalItemStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  NEEDS_CLARIFICATION
}

enum VoiceNoteStatus {
  DRAFT
  AWAITING_TRANSCRIPTION
  TRANSCRIBED
  TRANSCRIPTION_FAILED
  READY_FOR_REVIEW
  REVIEWED
  DELETED
}

enum VoiceAudioRetentionStatus {
  NOT_STORED
  PENDING_DELETION
  DELETED
  RETAINED_WITH_CONSENT
}

enum VoiceMentionType {
  PERSON
  COMPANY
  MEETING
  NOTE
  TASK
  COMMITMENT
  NEED
  CAPABILITY
  INTRODUCTION_SUGGESTION
  UNKNOWN
}

model User {
  id                             String                   @id @default(cuid())
  name                           String?
  email                          String?                  @unique
  emailVerified                  DateTime?                @map("email_verified")
  image                          String?
  accounts                       Account[]
  sessions                       Session[]
  memberships                    Membership[]
  auditLogs                      AuditLog[]               @relation("AuditActor")
  defaultTenant                  Tenant?                  @relation("DefaultTenantOwner")
  createdPeople                  Person[]                 @relation("PersonCreatedBy")
  updatedPeople                  Person[]                 @relation("PersonUpdatedBy")
  createdCompanies               Company[]                @relation("CompanyCreatedBy")
  updatedCompanies               Company[]                @relation("CompanyUpdatedBy")
  createdCompanyAffiliations     CompanyAffiliation[]     @relation("CompanyAffiliationCreatedBy")
  updatedCompanyAffiliations     CompanyAffiliation[]     @relation("CompanyAffiliationUpdatedBy")
  createdMeetings                Meeting[]                @relation("MeetingCreatedBy")
  updatedMeetings                Meeting[]                @relation("MeetingUpdatedBy")
  createdMeetingParticipants     MeetingParticipant[]     @relation("MeetingParticipantCreatedBy")
  updatedMeetingParticipants     MeetingParticipant[]     @relation("MeetingParticipantUpdatedBy")
  createdNotes                   Note[]                   @relation("NoteCreatedBy")
  updatedNotes                   Note[]                   @relation("NoteUpdatedBy")
  createdTasks                   Task[]                   @relation("TaskCreatedBy")
  updatedTasks                   Task[]                   @relation("TaskUpdatedBy")
  createdCommitments             Commitment[]             @relation("CommitmentCreatedBy")
  updatedCommitments             Commitment[]             @relation("CommitmentUpdatedBy")
  createdNeeds                   Need[]                   @relation("NeedCreatedBy")
  updatedNeeds                   Need[]                   @relation("NeedUpdatedBy")
  createdCapabilities            Capability[]             @relation("CapabilityCreatedBy")
  updatedCapabilities            Capability[]             @relation("CapabilityUpdatedBy")
  createdIntroductionSuggestions IntroductionSuggestion[] @relation("IntroductionSuggestionCreatedBy")
  updatedIntroductionSuggestions IntroductionSuggestion[] @relation("IntroductionSuggestionUpdatedBy")
  createdAIProposals             AIProposal[]             @relation("AIProposalCreatedBy")
  reviewedAIProposals            AIProposal[]             @relation("AIProposalReviewedBy")
  createdAIProposalItems         AIProposalItem[]         @relation("AIProposalItemCreatedBy")
  reviewedAIProposalItems        AIProposalItem[]         @relation("AIProposalItemReviewedBy")
  createdVoiceNotes              VoiceNote[]              @relation("VoiceNoteCreatedBy")
  updatedVoiceNotes              VoiceNote[]              @relation("VoiceNoteUpdatedBy")
  createdVoiceMentions           VoiceMention[]           @relation("VoiceMentionCreatedBy")
  updatedVoiceMentions           VoiceMention[]           @relation("VoiceMentionUpdatedBy")
  confirmedVoiceMentions         VoiceMention[]           @relation("VoiceMentionConfirmedBy")
  createdSourceReferences        SourceReference[]        @relation("SourceReferenceCreatedBy")
  createdAt                      DateTime                 @default(now()) @map("created_at")
  updatedAt                      DateTime                 @updatedAt @map("updated_at")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Tenant {
  id                      String                   @id @default(cuid())
  name                    String
  slug                    String                   @unique
  defaultForUserId        String?                  @unique @map("default_for_user_id")
  defaultForUser          User?                    @relation("DefaultTenantOwner", fields: [defaultForUserId], references: [id], onDelete: SetNull)
  memberships             Membership[]
  auditLogs               AuditLog[]
  people                  Person[]
  companies               Company[]
  companyAffiliations     CompanyAffiliation[]
  meetings                Meeting[]
  meetingParticipants     MeetingParticipant[]
  notes                   Note[]
  tasks                   Task[]
  commitments             Commitment[]
  needs                   Need[]
  capabilities            Capability[]
  introductionSuggestions IntroductionSuggestion[]
  aiProposals             AIProposal[]
  aiProposalItems         AIProposalItem[]
  voiceNotes              VoiceNote[]
  voiceMentions           VoiceMention[]
  sourceReferences        SourceReference[]
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")

  @@map("tenants")
}

model Role {
  id          String       @id @default(cuid())
  key         RoleKey      @unique
  name        String
  description String?
  memberships Membership[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@map("roles")
}

model Membership {
  id        String           @id @default(cuid())
  tenantId  String           @map("tenant_id")
  userId    String           @map("user_id")
  roleId    String           @map("role_id")
  status    MembershipStatus @default(ACTIVE)
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role             @relation(fields: [roleId], references: [id], onDelete: Restrict)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([roleId])
  @@map("memberships")
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String?  @map("tenant_id")
  actorUserId String?  @map("actor_user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  metadata    Json?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action])
  @@map("audit_logs")
}

model Person {
  id                          String                   @id @default(cuid())
  tenantId                    String                   @map("tenant_id")
  displayName                 String                   @map("display_name")
  firstName                   String?                  @map("first_name")
  lastName                    String?                  @map("last_name")
  email                       String?
  phone                       String?
  jobTitle                    String?                  @map("job_title")
  linkedinUrl                 String?                  @map("linkedin_url")
  salesNavigatorUrl           String?                  @map("sales_navigator_url")
  relationshipStatus          RelationshipStatus       @default(UNKNOWN) @map("relationship_status")
  relationshipTemperature     RelationshipTemperature  @default(UNKNOWN) @map("relationship_temperature")
  createdByUserId             String?                  @map("created_by_user_id")
  updatedByUserId             String?                  @map("updated_by_user_id")
  archivedAt                  DateTime?                @map("archived_at")
  tenant                      Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser               User?                    @relation("PersonCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser               User?                    @relation("PersonUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  companyAffiliations         CompanyAffiliation[]     @relation("PersonCompanyAffiliations")
  meetingParticipants         MeetingParticipant[]     @relation("PersonMeetingParticipants")
  notes                       Note[]                   @relation("PersonNotes")
  tasks                       Task[]                   @relation("PersonTasks")
  ownedCommitments            Commitment[]             @relation("CommitmentOwnerPerson")
  counterpartyCommitments     Commitment[]             @relation("CommitmentCounterpartyPerson")
  needs                       Need[]                   @relation("PersonNeeds")
  capabilities                Capability[]             @relation("PersonCapabilities")
  introductionSuggestionsFrom IntroductionSuggestion[] @relation("IntroductionFromPerson")
  introductionSuggestionsTo   IntroductionSuggestion[] @relation("IntroductionToPerson")
  voiceNotes                  VoiceNote[]              @relation("PersonVoiceNotes")
  createdAt                   DateTime                 @default(now()) @map("created_at")
  updatedAt                   DateTime                 @updatedAt @map("updated_at")

  @@unique([id, tenantId])
  @@index([tenantId, displayName])
  @@index([tenantId, email])
  @@index([tenantId, archivedAt])
  @@map("people")
}

model Company {
  id                          String                   @id @default(cuid())
  tenantId                    String                   @map("tenant_id")
  name                        String
  normalizedName              String?                  @map("normalized_name")
  website                     String?
  industry                    String?
  description                 String?
  createdByUserId             String?                  @map("created_by_user_id")
  updatedByUserId             String?                  @map("updated_by_user_id")
  archivedAt                  DateTime?                @map("archived_at")
  tenant                      Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser               User?                    @relation("CompanyCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser               User?                    @relation("CompanyUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  companyAffiliations         CompanyAffiliation[]     @relation("CompanyAffiliations")
  primaryMeetings             Meeting[]                @relation("MeetingPrimaryCompany")
  meetingParticipants         MeetingParticipant[]     @relation("CompanyMeetingParticipants")
  notes                       Note[]                   @relation("CompanyNotes")
  tasks                       Task[]                   @relation("CompanyTasks")
  ownedCommitments            Commitment[]             @relation("CommitmentOwnerCompany")
  counterpartyCommitments     Commitment[]             @relation("CommitmentCounterpartyCompany")
  needs                       Need[]                   @relation("CompanyNeeds")
  capabilities                Capability[]             @relation("CompanyCapabilities")
  introductionSuggestionsFrom IntroductionSuggestion[] @relation("IntroductionFromCompany")
  introductionSuggestionsTo   IntroductionSuggestion[] @relation("IntroductionToCompany")
  voiceNotes                  VoiceNote[]              @relation("CompanyVoiceNotes")
  createdAt                   DateTime                 @default(now()) @map("created_at")
  updatedAt                   DateTime                 @updatedAt @map("updated_at")

  @@unique([id, tenantId])
  @@index([tenantId, name])
  @@index([tenantId, normalizedName])
  @@index([tenantId, archivedAt])
  @@map("companies")
}

model CompanyAffiliation {
  id               String    @id @default(cuid())
  tenantId         String    @map("tenant_id")
  personId         String    @map("person_id")
  companyId        String    @map("company_id")
  affiliationTitle String?   @map("affiliation_title")
  department       String?
  startsAt         DateTime? @map("starts_at")
  endsAt           DateTime? @map("ends_at")
  isPrimary        Boolean   @default(false) @map("is_primary")
  createdByUserId  String?   @map("created_by_user_id")
  updatedByUserId  String?   @map("updated_by_user_id")
  archivedAt       DateTime? @map("archived_at")
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  person           Person    @relation("PersonCompanyAffiliations", fields: [personId, tenantId], references: [id, tenantId], onDelete: Cascade)
  company          Company   @relation("CompanyAffiliations", fields: [companyId, tenantId], references: [id, tenantId], onDelete: Cascade)
  createdByUser    User?     @relation("CompanyAffiliationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser    User?     @relation("CompanyAffiliationUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@unique([id, tenantId])
  @@index([tenantId, personId])
  @@index([tenantId, companyId])
  @@index([tenantId, archivedAt])
  @@map("company_affiliations")
}

model Meeting {
  id               String               @id @default(cuid())
  tenantId         String               @map("tenant_id")
  title            String
  occurredAt       DateTime?            @map("occurred_at")
  endedAt          DateTime?            @map("ended_at")
  location         String?
  summary          String?
  sourceType       RecordSourceType     @default(MANUAL) @map("source_type")
  primaryCompanyId String?              @map("primary_company_id")
  createdByUserId  String?              @map("created_by_user_id")
  updatedByUserId  String?              @map("updated_by_user_id")
  archivedAt       DateTime?            @map("archived_at")
  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  primaryCompany   Company?             @relation("MeetingPrimaryCompany", fields: [primaryCompanyId, tenantId], references: [id, tenantId], onDelete: Restrict)
  participants     MeetingParticipant[] @relation("MeetingParticipants")
  notes            Note[]               @relation("MeetingNotes")
  tasks            Task[]               @relation("MeetingTasks")
  commitments      Commitment[]         @relation("MeetingCommitments")
  needs            Need[]               @relation("MeetingNeeds")
  aiProposals      AIProposal[]         @relation("MeetingAIProposals")
  voiceNotes       VoiceNote[]          @relation("MeetingVoiceNotes")
  createdByUser    User?                @relation("MeetingCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser    User?                @relation("MeetingUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  @@unique([id, tenantId])
  @@index([tenantId, occurredAt])
  @@index([tenantId, primaryCompanyId])
  @@index([tenantId, sourceType])
  @@index([tenantId, archivedAt])
  @@map("meetings")
}

model MeetingParticipant {
  id              String                 @id @default(cuid())
  tenantId        String                 @map("tenant_id")
  meetingId       String                 @map("meeting_id")
  personId        String?                @map("person_id")
  companyId       String?                @map("company_id")
  nameSnapshot    String?                @map("name_snapshot")
  emailSnapshot   String?                @map("email_snapshot")
  participantRole MeetingParticipantRole @default(UNKNOWN) @map("participant_role")
  createdByUserId String?                @map("created_by_user_id")
  updatedByUserId String?                @map("updated_by_user_id")
  tenant          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  meeting         Meeting                @relation("MeetingParticipants", fields: [meetingId, tenantId], references: [id, tenantId], onDelete: Cascade)
  person          Person?                @relation("PersonMeetingParticipants", fields: [personId, tenantId], references: [id, tenantId], onDelete: Restrict)
  company         Company?               @relation("CompanyMeetingParticipants", fields: [companyId, tenantId], references: [id, tenantId], onDelete: Restrict)
  createdByUser   User?                  @relation("MeetingParticipantCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser   User?                  @relation("MeetingParticipantUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  @@unique([id, tenantId])
  @@unique([tenantId, meetingId, personId])
  @@index([tenantId, meetingId])
  @@index([tenantId, personId])
  @@index([tenantId, companyId])
  @@map("meeting_participants")
}

model Note {
  id              String           @id @default(cuid())
  tenantId        String           @map("tenant_id")
  body            String
  summary         String?
  noteType        NoteType         @default(GENERAL) @map("note_type")
  sourceType      RecordSourceType @default(MANUAL) @map("source_type")
  sensitivity     Sensitivity      @default(NORMAL)
  personId        String?          @map("person_id")
  companyId       String?          @map("company_id")
  meetingId       String?          @map("meeting_id")
  createdByUserId String?          @map("created_by_user_id")
  updatedByUserId String?          @map("updated_by_user_id")
  archivedAt      DateTime?        @map("archived_at")
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  person          Person?          @relation("PersonNotes", fields: [personId, tenantId], references: [id, tenantId], onDelete: Restrict)
  company         Company?         @relation("CompanyNotes", fields: [companyId, tenantId], references: [id, tenantId], onDelete: Restrict)
  meeting         Meeting?         @relation("MeetingNotes", fields: [meetingId, tenantId], references: [id, tenantId], onDelete: Restrict)
  tasks           Task[]           @relation("NoteTasks")
  commitments     Commitment[]     @relation("NoteCommitments")
  needs           Need[]           @relation("NoteNeeds")
  capabilities    Capability[]     @relation("NoteCapabilities")
  aiProposals     AIProposal[]     @relation("NoteAIProposals")
  voiceNotes      VoiceNote[]      @relation("NoteVoiceNotes")
  createdByUser   User?            @relation("NoteCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser   User?            @relation("NoteUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@unique([id, tenantId])
  @@index([tenantId, noteType])
  @@index([tenantId, sourceType])
  @@index([tenantId, personId])
  @@index([tenantId, companyId])
  @@index([tenantId, meetingId])
  @@index([tenantId, archivedAt])
  @@map("notes")
}

model Task {
  id                       String                  @id @default(cuid())
  tenantId                 String                  @map("tenant_id")
  title                    String
  description              String?
  status                   TaskStatus              @default(OPEN)
  priority                 TaskPriority            @default(MEDIUM)
  taskType                 TaskType                @default(FOLLOW_UP) @map("task_type")
  dueAt                    DateTime?               @map("due_at")
  reminderAt               DateTime?               @map("reminder_at")
  snoozedUntil             DateTime?               @map("snoozed_until")
  completedAt              DateTime?               @map("completed_at")
  whyNowRationale          String?                 @map("why_now_rationale")
  confidence               Float?
  personId                 String?                 @map("person_id")
  companyId                String?                 @map("company_id")
  meetingId                String?                 @map("meeting_id")
  noteId                   String?                 @map("note_id")
  commitmentId             String?                 @map("commitment_id")
  introductionSuggestionId String?                 @map("introduction_suggestion_id")
  createdByUserId          String?                 @map("created_by_user_id")
  updatedByUserId          String?                 @map("updated_by_user_id")
  archivedAt               DateTime?               @map("archived_at")
  tenant                   Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  person                   Person?                 @relation("PersonTasks", fields: [personId, tenantId], references: [id, tenantId], onDelete: Restrict)
  company                  Company?                @relation("CompanyTasks", fields: [companyId, tenantId], references: [id, tenantId], onDelete: Restrict)
  meeting                  Meeting?                @relation("MeetingTasks", fields: [meetingId, tenantId], references: [id, tenantId], onDelete: Restrict)
  note                     Note?                   @relation("NoteTasks", fields: [noteId, tenantId], references: [id, tenantId], onDelete: Restrict)
  commitment               Commitment?             @relation("CommitmentTasks", fields: [commitmentId, tenantId], references: [id, tenantId], onDelete: Restrict)
  introductionSuggestion   IntroductionSuggestion? @relation("IntroductionSuggestionTasks", fields: [introductionSuggestionId, tenantId], references: [id, tenantId], onDelete: Restrict)
  createdByUser            User?                   @relation("TaskCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser            User?                   @relation("TaskUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  createdAt                DateTime                @default(now()) @map("created_at")
  updatedAt                DateTime                @updatedAt @map("updated_at")

  @@unique([id, tenantId])
  @@index([tenantId, status, dueAt])
  @@index([tenantId, reminderAt])
  @@index([tenantId, personId])
  @@index([tenantId, companyId])
  @@index([tenantId, meetingId])
  @@index([tenantId, noteId])
  @@index([tenantId, commitmentId])
  @@index([tenantId, introductionSuggestionId])
  @@index([tenantId, archivedAt])
  @@map("tasks")
}

model Commitment {
  id                    String              @id @default(cuid())
  tenantId              String              @map("tenant_id")
  ownerType             CommitmentOwnerType @default(UNKNOWN) @map("owner_type")
  ownerPersonId         String?             @map("owner_person_id")
  ownerCompanyId        String?             @map("owner_company_id")
  counterpartyPersonId  String?             @map("counterparty_person_id")
  counterpartyCompanyId String?             @map("counterparty_company_id")
  title                 String
  description           String?
  dueAt                 DateTime?           @map("due_at")
  dueWindowStart        DateTime?           @map("due_window_start")
  dueWindowEnd          DateTime?           @map("due_window_end")
  status                CommitmentStatus    @default(OPEN)
  sensitivity           Sensitivity         @default(NORMAL)
  meetingId             String?             @map("meeting_id")
  noteId                String?             @map("note_id")
  createdByUserId       String?             @map("created_by_user_id")
  updatedByUserId       String?             @map("updated_by_user_id")
  archivedAt            DateTime?           @map("archived_at")
  tenant                Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerPerson           Person?             @relation("CommitmentOwnerPerson", fields: [ownerPersonId, tenantId], references: [id, tenantId], onDelete: Restrict)
  ownerCompany          Company?            @relation("CommitmentOwnerCompany", fields: [ownerCompanyId, tenantId], references: [id, tenantId], onDelete: Restrict)
