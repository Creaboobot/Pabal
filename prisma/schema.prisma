  counterpartyCompany   Company?            @relation("CommitmentCounterpartyCompany", fields: [counterpartyCompanyId, tenantId], references: [id, tenantId], onDelete: Restrict)
  meeting               Meeting?            @relation("MeetingCommitments", fields: [meetingId, tenantId], references: [id, tenantId], onDelete: Restrict)
  note                  Note?               @relation("NoteCommitments", fields: [noteId, tenantId], references: [id, tenantId], onDelete: Restrict)
