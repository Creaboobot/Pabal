# Public hosting example
# Copy values into your hosting provider secret store. Do not commit real
# secrets or production connection strings.

# App
APP_URL=https://pabal.example.com
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
APP_PORT=3000

# Auth
# Generate a long random value for every public environment.
AUTH_SECRET=replace-with-a-long-random-production-secret
AUTH_TRUST_HOST=true
ENABLE_DEV_AUTH=false

# Microsoft Entra sign-in provider. Required for normal production sign-in
# unless another production auth provider is added later.
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=

# Database
# Vercel/Neon: set this to the Neon pooled PostgreSQL connection string.
# Docker public compose: the default below targets the bundled postgres service.
POSTGRES_DB=pobal
POSTGRES_USER=pobal
POSTGRES_PASSWORD=replace-with-a-long-random-db-password
DATABASE_URL=postgresql://pobal:replace-with-a-long-random-db-password@postgres:5432/pobal?schema=public

# OpenAI / AI provider adapters
# These are runtime-only. Builds and readiness checks do not require them.
SPEECH_TO_TEXT_PROVIDER=openai
TRANSCRIPT_STRUCTURING_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_STRUCTURING_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=

# Storage, jobs, billing, telemetry
STORAGE_PROVIDER=s3
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
JOB_PROVIDER=inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
BILLING_PROVIDER=disabled
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
SENTRY_DSN=

# Feature flags
FEATURE_MICROSOFT_GRAPH=false
FEATURE_LINKEDIN_MANUAL_ENRICHMENT=true
FEATURE_VOICE_CAPTURE=true
FEATURE_BILLING=false

# Microsoft Graph readiness only. Keep disabled until intentionally implemented.
MICROSOFT_GRAPH_PROVIDER=disabled
MICROSOFT_GRAPH_CLIENT_ID=
MICROSOFT_GRAPH_CLIENT_SECRET=
MICROSOFT_GRAPH_TENANT_ID=
MICROSOFT_GRAPH_AUTHORITY=
MICROSOFT_GRAPH_REDIRECT_URI=
